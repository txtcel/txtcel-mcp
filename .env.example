# --- RPC provider (network is decided purely by these values) ---
# REQUIRED. HTTP endpoint of the cluster where TXTCEL_PROGRAM_ID is deployed
# (there is no default — a silent devnet fallback paired with a mainnet program
# id would fail confusingly). For a paid provider (Helius / QuickNode / Triton)
# put the full URL incl. API key here.
TXTCEL_RPC=

# Optional explicit WebSocket endpoint. Leave empty to let web3.js derive it
# from TXTCEL_RPC. Some providers require an explicit ws URL.
# TXTCEL_WS=wss://api.devnet.solana.com

# Optional commitment level (processed | confirmed | finalized). Default: confirmed
# TXTCEL_COMMITMENT=confirmed

# Optional ComputeBudget priority fee in micro-lamports per compute unit,
# applied to every transaction. Default 10000; set 0 to disable. On mainnet
# transactions without a priority fee are routinely dropped under load.
# TXTCEL_PRIORITY_FEE=10000

# --- Program ---
# REQUIRED. Address the Txtcel program is deployed at on the chosen cluster.
TXTCEL_PROGRAM_ID=

# --- Agent identity / signing wallet ---
# REQUIRED: provide ONE of the following. Resolution order:
#   1. TXTCEL_SECRET_KEY  2. TXTCEL_KEYPAIR
# Use a DEDICATED keypair funded with only what the agent needs. Personal
# wallets (e.g. ~/.config/solana/id.json) are NEVER used implicitly — there is
# no fallback.
#
# Raw secret key: a JSON array of 64 bytes, or a base58 string.
# TXTCEL_SECRET_KEY=[12,34,...]
#
# Path to a Solana keypair JSON file (prefer a file with 600 permissions over
# an inline secret in MCP client config).
# TXTCEL_KEYPAIR=/path/to/dedicated-agent-keypair.json
